# --- Clés API du moteur Bob.io ---
# Copie ce fichier en ".env.local" puis colle tes clés ci-dessous.

# Transcription (Groq Whisper) — gratuit : https://console.groq.com/keys
GROQ_API_KEY=

# Détection des moments forts — par défaut Groq (GRATUIT, même clé ci-dessus).
# Claude est OPTIONNEL : ne le remplis que si tu veux la détection premium.
# Il faut alors aussi mettre BOB_MOMENTS_PROVIDER=claude ci-dessous.
ANTHROPIC_API_KEY=

# Espace administrateur (/admin) — change ce mot de passe.
ADMIN_PASSWORD=bob-admin

# Optionnel : changer de fournisseur / modèles
# BOB_MOMENTS_PROVIDER=claude          # défaut: groq (gratuit)
# BOB_GROQ_MODEL=whisper-large-v3-turbo
# BOB_GROQ_LLM_MODEL=llama-3.3-70b-versatile
# BOB_CLAUDE_MODEL=claude-sonnet-4-6
